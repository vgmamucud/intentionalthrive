{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "content.intentionalthrive.com" }],
      "destination": "/content/index.html"
    }
  ]
}
