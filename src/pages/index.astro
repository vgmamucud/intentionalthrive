---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const recentArticles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<Base
  title="Intentional Thrive — Financial Clarity for Filipino Professionals"
  description="A modern financial clarity space for Filipino professionals who want to protect what matters and build with intention."
>

  <section class="brand-hero">
    <div class="container--wide hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Intentional Thrive</p>
        <h1>Build wealth with clarity and intention.</h1>
        <p class="hero-sub">For Filipino professionals who are earning, leading, parenting, planning, and quietly wondering if their money is finally working in the right direction.</p>
        <div class="hero-actions">
          <a href="/about#connect" class="btn btn--primary">Get Free Assessment</a>
          <a href="#clarity-map" class="btn btn--outline">See the clarity map</a>
        </div>
      </div>

      <div class="hero-panel" aria-label="Intentional Thrive readiness snapshot">
        <div class="panel-header">
          <span>Thrive Readiness</span>
          <strong>Start with the gaps.</strong>
        </div>
        <div class="readiness-bars">
          <div class="readiness-row">
            <span>Protection</span>
            <div><i style="width: 72%"></i></div>
          </div>
          <div class="readiness-row">
            <span>Cash Flow</span>
            <div><i style="width: 48%"></i></div>
          </div>
          <div class="readiness-row">
            <span>Growth Plan</span>
            <div><i style="width: 58%"></i></div>
          </div>
          <div class="readiness-row">
            <span>Intention</span>
            <div><i style="width: 86%"></i></div>
          </div>
        </div>
        <p>No pressure. No jargon. Just a clear next step.</p>
      </div>
    </div>
  </section>

  <section class="proof-band">
    <div class="container--wide proof-grid">
      <div><strong>Since 2019</strong><span>Financial services experience</span></div>
      <div><strong>600+</strong><span>Policies under care</span></div>
      <div><strong>2023</strong><span>Unit manager</span></div>
      <div><strong>PH</strong><span>Built for Filipino professionals</span></div>
    </div>
  </section>

  <section class="clarity-map" id="clarity-map">
    <div class="container--wide">
      <div class="section-heading">
        <p class="eyebrow">The Clarity Map</p>
        <h2>Know what to fix before buying anything new.</h2>
        <p>The first goal is not a product. It is understanding what your current financial life is asking from you.</p>
      </div>

      <div class="map-grid">
        <article>
          <span>01</span>
          <h3>See the money pattern</h3>
          <p>Where income goes, what keeps repeating, and why higher earnings may still feel tight.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Check the protection gap</h3>
          <p>What happens if income stops, health changes, or your family needs support quickly.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Build the next move</h3>
          <p>A practical sequence for savings, coverage, investing, and long-term family goals.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="decision-section">
    <div class="container--wide decision-grid">
      <div class="decision-card primary">
        <p class="eyebrow">For Clients</p>
        <h2>Start with a free financial readiness assessment.</h2>
        <p>Get a calm review of your current situation: budget, family responsibilities, insurance, risk, and goals.</p>
        <a href="/about#connect" class="btn btn--primary">Book the assessment</a>
      </div>
      <div class="decision-card dark">
        <p class="eyebrow">For Future Advisors</p>
        <h2>Explore a career built on service and clarity.</h2>
        <p>If you want meaningful work with income growth and mentorship, start a conversation with Venus.</p>
        <a href="/about#connect" class="btn btn--dark">Join the team</a>
      </div>
    </div>
  </section>

  <section class="guide-section">
    <div class="container--wide guide-grid">
      <div>
        <p class="eyebrow">Your Guide</p>
        <h2>Venus helps make the financial conversation easier to understand.</h2>
      </div>
      <div class="guide-copy">
        <p>Venus is a Pru Life UK Unit Manager, mom, wife, and founder of Intentional Thrive. She created this space for professionals who want honest financial literacy, not overwhelming jargon.</p>
        <p>The work is simple: protect what matters, understand what you own, and build a life that matches your values.</p>
        <a href="/about" class="text-link">More about Venus →</a>
      </div>
    </div>
  </section>

  <section class="article-strip">
    <div class="container--wide">
      <div class="section-heading compact">
        <p class="eyebrow">Start Reading</p>
        <h2>Practical notes for an intentional financial life.</h2>
      </div>
      <div class="article-grid">
        {recentArticles.map(article => (
          <a href={`/blog/${article.slug}`} class="article-card">
            <span>{article.data.pillar}</span>
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="final-banner">
    <div class="container">
      <p class="eyebrow">Ready when you are</p>
      <h2>One clear conversation can change the next decision.</h2>
      <a href="/about#connect" class="btn-white">Get Free Assessment</a>
    </div>
  </section>

</Base>

<style>
.brand-hero {
  background:
    linear-gradient(135deg, rgba(24, 48, 40, 0.96), rgba(16, 27, 23, 0.98)),
    url('/images/intentional-thrive-planning.png');
  background-position: center;
  background-size: cover;
  color: #fff;
  padding: 108px 0 92px;
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 390px;
  gap: 56px;
  align-items: center;
}

.eyebrow {
  color: var(--color-accent);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.1em;
  margin-bottom: 16px;
  text-transform: uppercase;
}

.hero-copy h1 {
  color: #fff;
  font-family: var(--font-serif);
  font-size: clamp(52px, 8vw, 92px);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 0.96;
  max-width: 820px;
}

.hero-sub {
  color: rgba(255, 255, 255, 0.84);
  font-size: 18px;
  line-height: 1.75;
  margin: 26px 0 32px;
  max-width: 640px;
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.brand-hero .btn--outline {
  border-color: rgba(255, 255, 255, 0.32);
  color: #fff;
}

.brand-hero .btn--outline:hover {
  background: #fff;
  border-color: #fff;
  color: var(--color-dark);
}

.hero-panel {
  background: #fbfaf8;
  border-radius: 18px;
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
  color: var(--color-dark) !important;
  padding: 28px;
}

.panel-header {
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 22px;
  padding-bottom: 18px;
}

.panel-header span {
  color: #4f8a60 !important;
  display: block;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.panel-header strong {
  color: #183028 !important;
  display: block;
  font-size: 26px;
  font-weight: 900;
  letter-spacing: -0.03em;
  margin-top: 5px;
}

.readiness-bars {
  display: grid;
  gap: 16px;
}

.readiness-row {
  display: grid;
  gap: 7px;
}

.readiness-row span {
  color: #183028 !important;
  font-size: 13px;
  font-weight: 800;
}

.readiness-row div {
  background: #ece8e2;
  border-radius: 999px;
  height: 10px;
  overflow: hidden;
}

.readiness-row i {
  background: var(--color-accent);
  border-radius: inherit;
  display: block;
  height: 100%;
}

.hero-panel p {
  color: #555555 !important;
  font-size: 14px;
  margin-top: 22px;
}

.proof-band {
  background: #fff;
  border-bottom: 1px solid var(--color-border);
  padding: 28px 0;
}

.proof-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.proof-grid div {
  border-left: 3px solid var(--color-accent);
  padding-left: 16px;
}

.proof-grid strong {
  color: var(--color-dark);
  display: block;
  font-size: 28px;
  font-weight: 900;
  letter-spacing: -0.04em;
}

.proof-grid span {
  color: var(--color-text-muted);
  font-size: 13px;
}

.clarity-map,
.decision-section,
.guide-section,
.article-strip {
  padding: 88px 0;
}

.section-heading {
  margin: 0 auto 46px;
  max-width: 720px;
  text-align: center;
}

.section-heading.compact {
  max-width: 650px;
}

.section-heading h2,
.decision-card h2,
.guide-grid h2,
.final-banner h2 {
  font-size: clamp(36px, 6vw, 64px);
  letter-spacing: -0.045em;
  line-height: 1;
}

.section-heading p:not(.eyebrow) {
  color: var(--color-text-muted);
  font-size: 17px;
  line-height: 1.7;
  margin-top: 18px;
}

.map-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.map-grid article {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 18px;
  padding: 30px;
}

.map-grid span {
  color: var(--color-accent);
  font-size: 13px;
  font-weight: 900;
}

.map-grid h3,
.article-card h3 {
  color: var(--color-dark);
  font-size: 22px;
  font-weight: 900;
  letter-spacing: -0.03em;
  margin: 14px 0 12px;
}

.map-grid p,
.decision-card p,
.guide-copy p,
.article-card p {
  color: var(--color-text-muted);
  line-height: 1.75;
}

.decision-section {
  background: #fff;
}

.decision-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22px;
}

.decision-card {
  border-radius: 20px;
  padding: 42px;
}

.decision-card.primary {
  background: var(--color-accent-pale);
  border: 1px solid rgba(232, 119, 34, 0.2);
}

.decision-card.dark {
  background: var(--color-dark);
}

.decision-card.dark h2,
.decision-card.dark p {
  color: #fff;
}

.decision-card p {
  font-size: 17px;
  margin: 18px 0 28px;
}

.btn--dark {
  background: #fff;
  color: var(--color-dark);
}

.btn--dark:hover {
  background: var(--color-accent);
  color: #fff;
}

.guide-section {
  background: var(--color-bg);
}

.guide-grid {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 58px;
  align-items: start;
}

.guide-copy {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 18px;
  padding: 34px;
}

.text-link {
  color: var(--color-accent);
  display: inline-block;
  font-weight: 900;
  margin-top: 10px;
}

.article-strip {
  background: #fff;
}

.article-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.article-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: 18px;
  color: inherit;
  padding: 26px;
  transition: transform 0.2s, border-color 0.2s;
}

.article-card:hover {
  border-color: rgba(232, 119, 34, 0.42);
  color: inherit;
  transform: translateY(-3px);
}

.article-card span {
  color: var(--color-accent);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.final-banner {
  background: var(--color-accent);
  padding: 84px 0;
  text-align: center;
}

.final-banner .eyebrow,
.final-banner h2 {
  color: #fff;
}

.final-banner h2 {
  margin: 0 auto 30px;
  max-width: 760px;
}

.btn-white {
  background: #fff;
  border-radius: 8px;
  color: var(--color-accent);
  display: inline-block;
  font-size: 16px;
  font-weight: 900;
  padding: 18px 34px;
}

.btn-white:hover {
  background: #f4f4f4;
  color: var(--color-accent);
}

@media (max-width: 900px) {
  .hero-grid,
  .decision-grid,
  .guide-grid,
  .article-grid,
  .map-grid {
    grid-template-columns: 1fr;
  }

  .proof-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .brand-hero {
    padding: 72px 0;
  }
}

@media (max-width: 560px) {
  .proof-grid {
    grid-template-columns: 1fr;
  }

  .decision-card,
  .guide-copy,
  .hero-panel {
    padding: 26px;
  }
}
</style>
