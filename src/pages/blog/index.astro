---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<Base
  title="Articles — Intentional Thrive"
  description="Money mindset, wealth planning, and intentional living for Filipino professionals."
>

  <header class="page-header">
    <div class="container">
      <span class="pill">Articles</span>
      <h1 style="margin-top:0.75rem;">Read. Think. Design.</h1>
      <p class="page-header__sub">Money mindset, wealth in practice, intentional living, and the journey — all in one place.</p>
    </div>
  </header>

  <main class="container--wide" style="padding: 3rem 1.5rem 5rem;">

    <div class="filter-bar">
      <span class="filter-bar__label">Filter by pillar:</span>
      <a href="#all" class="pill active">All</a>
      <a href="#mindset" class="pill">Money Mindset</a>
      <a href="#wealth" class="pill">Wealth in Practice</a>
      <a href="#living" class="pill">Intentional Living</a>
      <a href="#journey" class="pill">The Journey</a>
    </div>

    <div class="grid--articles" style="margin-top:2rem;">
      {articles.map(article => (
        <a href={`/blog/${article.slug}`} class="card card--link">
          <span class="card__tag">{article.data.pillar}</span>
          <div class="card__title">{article.data.title}</div>
          <p class="card__excerpt">{article.data.description}</p>
          <div class="card__meta">{article.data.readTime} read</div>
        </a>
      ))}
    </div>
  </main>

</Base>

<style>
.page-header {
  background: linear-gradient(135deg, #eaf2ec 0%, #f2ede4 100%);
  padding: 4rem 0 3rem;
}
.page-header__sub {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  margin-top: 0.5rem;
}
.filter-bar {
  display: flex;
  gap: 0.5rem;
  align-items: center;
  flex-wrap: wrap;
}
.filter-bar__label {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  margin-right: 0.25rem;
}
.card--link {
  text-decoration: none;
  display: block;
  color: inherit;
}
</style>
